{
  "name": "TelemStudio",
  "app_id": "studio.telem.overlay",
  "icon": "share/logo.png",
  "desktop_terminal": false,
  "desktop_categories": [
    "AudioVideo",
    "Video",
    "GTK"
  ],
  "gtk_theme": "Andromeda",
  "gtk_icon_theme": "Adwaita",
  "gtk_prefer_dark": true,
  "files": [
    {
      "path": "themes/Andromeda",
      "dest": "usr/share/themes/Andromeda"
    },
    {
      "path": "share/logo.png",
      "dest": "usr/share/icons/hicolor/1024x1024/apps/studio.telem.overlay.png"
    }
  ],
  "linux": {
    "deb": {
      "download": true,
      "packages": [
        "libgtk-4-1"
      ]
    },
    "arches": [
      {
        "arch": "x86_64",
        "build_dir": "build-x86_64",
        "build": [
          "cmake -E rm -rf \"$SQGI_LINUX_BUILD_DIR\"",
          "cmake -S \"$SQGI_SOURCE_DIR\" -B \"$SQGI_LINUX_BUILD_DIR\" -G Ninja ${SQGI_LINUX_CMAKE_TOOLCHAIN:+-DCMAKE_TOOLCHAIN_FILE=\"$SQGI_LINUX_CMAKE_TOOLCHAIN\"} -DCMAKE_BUILD_TYPE=Release",
          "cmake --build \"$SQGI_LINUX_BUILD_DIR\""
        ]
      },
      {
        "arch": "aarch64",
        "build_dir": "build-aarch64",
        "build": [
          "cmake -E rm -rf \"$SQGI_LINUX_BUILD_DIR\"",
          "cmake -S \"$SQGI_SOURCE_DIR\" -B \"$SQGI_LINUX_BUILD_DIR\" -G Ninja ${SQGI_LINUX_CMAKE_TOOLCHAIN:+-DCMAKE_TOOLCHAIN_FILE=\"$SQGI_LINUX_CMAKE_TOOLCHAIN\"} -DCMAKE_BUILD_TYPE=Release",
          "cmake --build \"$SQGI_LINUX_BUILD_DIR\""
        ]
      }
    ]
  },
  "windows": {
    "msys2_prefix": "mingw64",
    "build": [
      "cmake -E rm -rf \"$SQGI_WINDOWS_BUILD_DIR\"",
      "cmake -S \"$SQGI_SOURCE_DIR\" -B \"$SQGI_WINDOWS_BUILD_DIR\" -G Ninja -DCMAKE_TOOLCHAIN_FILE=\"$SQGI_WIN_CMAKE_TOOLCHAIN\" -DCMAKE_BUILD_TYPE=Release",
      "cmake --build \"$SQGI_WINDOWS_BUILD_DIR\" --target sqgi sqgi-bin"
    ],
    "build_dir": "build-win",
    "gtk_theme": "Andromeda",
    "gtk_icon_theme": "Adwaita",
    "gtk_prefer_dark": true,
    "gtk_font_name": "Segoe UI 10",
    "gdk_backend": "win32",
    "files": [
      {
        "path": "themes/Andromeda",
        "dest": "share/themes/Andromeda"
      },
      {
        "path": "share/logo.png",
        "dest": "share/icons/hicolor/1024x1024/apps/studio.telem.overlay.png"
      }
    ],
    "nsis_options": {
      "icon": "share/logo.ico",
      "desktop_shortcut": true,
      "start_menu_shortcut": true,
      "start_menu_folder": "SQGI"
    }
  }
}
